<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#0D0D12">

    <TextView
        android:text="⬡ Glyph Metronome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:textColor="#00FFE0"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/bpmText"
        android:text="180 BPM"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="64sp"
        android:textColor="#E8E8F0"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <SeekBar
        android:id="@+id/seekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:text="Rychlé předvolby"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#555570"
        android:textSize="13sp"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="40dp">

        <Button android:id="@+id/btn60"  android:text="60"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="4dp"/>
        <Button android:id="@+id/btn90"  android:text="90"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="4dp"/>
        <Button android:id="@+id/btn120" android:text="120"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="4dp"/>
        <Button android:id="@+id/btn140" android:text="140"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="4dp"/>
        <Button android:id="@+id/btn180" android:text="180"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_margin="4dp"/>
    </LinearLayout>

    <TextView
        android:text="Glyph Matrix bliká + vibruje na každý takt.\nPřízvuk na 1. době každého taktu."
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#555570"
        android:textSize="13sp"
        android:gravity="center"/>

</LinearLayout>